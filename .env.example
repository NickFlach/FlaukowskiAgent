# Database Configuration
DATABASE_URL=

# Node Environment
NODE_ENV=production

# API Configuration
PORT=5000

# Trading Configuration
TARGET_WALLET_ADDRESS=0xYourWalletAddressHere
VITE_TARGET_WALLET_ADDRESS=0xYourWalletAddressHere
SIMULATION_MODE=true

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_RECONNECT_DELAY=5000

# Market Data Update Intervals (in milliseconds)
MARKET_UPDATE_INTERVAL=5000
AGENT_CYCLE_INTERVAL=30000

# Risk Management Defaults
DEFAULT_MAX_DAILY_LOSS=5.00
DEFAULT_MAX_POSITION_SIZE=10.00
DEFAULT_CIRCUIT_BREAKER_ENABLED=true

# Frontend Configuration (for Vite)
VITE_API_URL=
VITE_WS_URL=